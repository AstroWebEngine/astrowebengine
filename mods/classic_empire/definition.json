{
  "meta": {
    "name": "Classic Empire",
    "version": "1.0",
    "description": "Neutral persistent hierarchical-galaxy 4X ruleset: single-resource economy, simultaneous combat, upgrade-level defenses, and a 20-ship tiered roster with generic names. The public showcase clone demonstrating the engine's classic flag corner; a faithful-named twin can live privately.",
    "author": "AstroWebEngine showcase"
  },
  "engine": {
    "resource_model": "single",
    "resource_types": [
      "credits"
    ],
    "defense_model": "level",
    "defenses_destructible": true,
    "defense_repair_percent": 0.0,
    "buildings_destructible": false,
    "ships_always_destroyed": true,
    "combat_model": "simultaneous",
    "combat_max_rounds": 1,
    "map_depth": 4,
    "map_levels": [
      "galaxy",
      "region",
      "system",
      "orbit"
    ],
    "construction_queue_max": 6,
    "research_queue_max": 6,
    "production_queue_max": 12,
    "report_categories": [
      "scanners",
      "player",
      "guild",
      "galaxy",
      "top_scouters",
      "top_jump_gates",
      "trade",
      "wormholes",
      "astros"
    ]
  },
