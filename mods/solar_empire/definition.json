{
  "meta": {
    "name": "Solar Empire",
    "version": "0.1",
    "description": "A Solar Empire-like adaptation (Generic-engine lineage). Captures the ship roster, commodity economy, and module-flavored weapons of SolarEmpireReborn as a loadable AstroWebEngine definition. Approximate, not a line-for-line clone — see docs/example_mods.md for the mapping and the engine-feature gaps (turns economy, graph map, bombs/bounty) that remain mod-hook/roadmap work.",
    "author": "AstroWebEngine example (from the user's SolarEmpireReborn)"
  },
  "engine": {
    "resource_model": "multi",
    "resource_types": ["credits", "metal", "fuel", "electronics", "organics"],
    "defense_model": "count",
    "defenses_destructible": true,
    "defense_repair_percent": 0.0,
    "buildings_destructible": false,
    "ships_always_destroyed": true,
    "combat_model": "simultaneous",
    "combat_max_rounds": 1,
    "economy_actions": "action_points",
    "action_points": {
      "start": 40,
      "regen_per_hour": 10,
      "max": 250,
      "apply_to_bots": false,
      "costs": {
        "fleet_send": 1, "fleet_recall": 1, "fleet_attack": 2, "fleet_conquer": 3,
        "colonize": 3, "ship_build": 1, "building_upgrade": 1, "defense_build": 1,
        "research_start": 1, "trade_create": 1, "trade_accept": 1, "trade_plunder": 2,
        "autoscout_enable": 1, "autoscout_hop": 1
      }
    },
    "map_topology": "graph",
    "graph": {
      "links_per_system": [2, 5],
      "wormhole_ratio": 0.05,
      "link_cost_model": "hops",
      "hop_distance": 20
    },
    "map_depth": 3,
    "map_levels": ["galaxy", "system", "slot"],
    "construction_queue_max": 6,
    "research_queue_max": 6,
    "production_queue_max": 12,
    "report_categories": ["scanners", "player", "guild", "galaxy", "trade", "astros"]
  },
  "tutorial": false,
  "economy": {
    "construction_bonus_base": 20,
    "construction_bonus_homeworld": 20,
    "base_energy_bonus": 2,
    "capital_empire_bonus": 1,
    "occupation_time_penalty": 1.3,
    "min_build_time_seconds": 5,
    "min_research_time_seconds": 5
  },
  "combat": {
    "damage_allocation_exponent": 0.85,
    "loot_percent": 0.2,
    "debris_percent": 0.4
