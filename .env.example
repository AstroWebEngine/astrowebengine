# AstroWebEngine configuration. Copy to `.env` and edit.
#   cp .env.example .env

# REQUIRED in production.
# JWTs are signed with this key. If unset, a RANDOM key is generated at startup,
# which logs every player out on each restart. Set a long, stable random value:
#   python -c "import secrets; print(secrets.token_hex(32))"
AWE_SECRET_KEY=change-me-to-a-long-random-hex-string

# --- Game definition (optional) ---
# Path (inside the container) to the game definition loaded at startup.
# Omit to use the engine's built-in default ruleset.
# AWE_GAME_DEFINITION=game_definitions/your_definition.json

# Global game-speed multiplier (build/economy times scale by this). Default: 1
# AWE_GAME_SPEED=1

# --- Database (optional) ---
# Default: bundled SQLite on the `awe-data` volume (no setting needed).
# For PostgreSQL, start with `--profile postgres` and uncomment:
# DATABASE_URL=postgresql+psycopg://awe:changeme@db:5432/awe

# --- Public engine registry (optional, opt-in, default off) ---
# List this server in the shared AstroWebEngine directory.
# AWE_REGISTRY_ENABLED=0
# AWE_REGISTRY_URL=https://registry.astrowebengine.com
# AWE_REGISTRY_PUBLIC_URL=https://your-server.example.com
# AWE_REGISTRY_DESCRIPTION=My space-strategy server
